[Unit]
Description=Auto RPM Builder Webhook
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
EnvironmentFile=-/etc/auto-rpm-builder.env
ExecStart=/usr/bin/python3 /opt/packager/scripts/webhook_server.py
WorkingDirectory=/opt/packager
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
