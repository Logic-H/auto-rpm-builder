{
  "schema_version": 1,
  "name": "ghostty",
  "enabled": true,
  "notes": "Rebuilt for EL10 from official ghostty source using the upstream COPR packaging spec.",
  "requires": [
    "gtk4-layer-shell"
  ],
  "source": {
    "type": "git",
    "repo": "https://github.com/scottames/copr.git",
    "ref": "main"
  },
  "build": {
    "method": "rpmbuild-spec",
    "spec_path": "ghostty/ghostty.spec",
    "spec_override": "packaging/ghostty/ghostty.el10.spec",
    "extra_sources": [
      "packaging/ghostty/ghostty-harfbuzz-el10.patch"
    ],
    "install_from_repo": [
      "gtk4-layer-shell"
    ],
    "publish_exclude_patterns": [
      "-debuginfo-",
      "-debugsource-",
      "\\.src\\.rpm$"
    ]
  },
  "test": {
    "install": [
      "ghostty"
    ],
    "env": {},
    "pre_install_commands": [],
    "files": [
      "/usr/bin/ghostty",
      "/usr/share/applications/com.mitchellh.ghostty.desktop"
    ],
    "unit_files": [],
    "commands": [
      "grep -q '^Exec=/usr/bin/ghostty' /usr/share/applications/com.mitchellh.ghostty.desktop"
    ],
    "post_install_commands": [
      "rpm -q ghostty >/dev/null"
    ]
  }
}
