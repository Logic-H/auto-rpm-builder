{
  "schema_version": 1,
  "name": "easyconnect",
  "enabled": true,
  "notes": "Sangfor EasyConnect vendor DEB rebuilt into an EL10 RPM for the Trilby repository.",
  "source": {
    "type": "url",
    "url": "http://download.sangfor.com.cn/download/product/sslvpn/pkg/linux_01/EasyConnect_x64.deb",
    "asset_name": "EasyConnect_x64.deb",
    "version": "7.6.3.7",
    "release_tag": "7.6.3.7-1"
  },
  "build": {
    "method": "rpm-from-deb",
    "release": "1",
    "license": "commercial",
    "summary": "EasyConnect for Linux",
    "description": "Sangfor EasyConnect for Linux rebuilt from the vendor DEB package.",
    "arch": "x86_64",
    "disable_check_rpaths": true,
    "executable_paths": [
      "/usr/share/sangfor/EasyConnect/EasyConnect"
    ]
  },
  "test": {
    "runner": "installroot",
    "install": [
      "easyconnect"
    ],
    "dnf_args": [],
    "env": {},
    "pre_install_commands": [],
    "files": [
      "/usr/share/sangfor/EasyConnect/EasyConnect",
      "/usr/share/applications/EasyConnect.desktop",
      "/usr/lib/systemd/system/EasyMonitor.service"
    ],
    "unit_files": [
      "EasyMonitor.service"
    ],
    "commands": [
      "test -e \"$SMOKE_ROOT/usr/share/sangfor/EasyConnect/EasyConnect\""
    ],
    "post_install_commands": [
      "rpm --root \"${INSTALLROOT}\" -q easyconnect >/dev/null"
    ]
  }
}
